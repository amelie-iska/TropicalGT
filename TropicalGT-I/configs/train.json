{
  "run_name": "tropicalgt_i_train",
  "data_root": "TropicalGT-I/data/toricgt/curated_hf_shards",
  "require_data": true,
  "cache_shards": 4,
  "shuffle": false,
  "chunk_shuffle": true,
  "chunk_shuffle_seed": 1729,
  "shuffle_rows_within_chunk": false,
  "num_workers": 0,
  "fixture_size": 8,
  "train_limit": null,
  "val_limit": 512,
  "seq_len": 256,
  "batch_size": 4,
  "max_steps": 2000,
  "lr": 0.0003,
  "weight_decay": 0.01,
  "grad_clip": 1.0,
  "device": "auto",
  "output_dir": "TropicalGT-I/outputs/train",
  "checkpoint_dir": "TropicalGT-I/checkpoints",
  "checkpoint_every": 250,
  "keys_path": "keys.txt",
  "viz_limit": 16,
  "tokengt": {"max_nodes": 64, "max_edges": 128, "node_id_dim": 16, "feature_dim": 48, "graph_token": true},
  "model": {"dim": 128, "hidden_dim": 128, "graph_feature_dim": 48, "num_actions": 8, "gflownet_weight": 0.02, "graphcg_weight": 0.02, "certificate_weight": 0.001, "wall_margin_threshold": 0.001},
  "inference_scaling": {"depth": 2, "width": 4, "branch_factor": 2},
  "wandb": {"enabled": true, "mode": "online", "project": "TropicalGT-I"}
}
