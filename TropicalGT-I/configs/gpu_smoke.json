{
  "run_name": "tropicalgt_i_gpu_smoke",
  "data_root": "TropicalGT-I/data/toricgt/curated_hf_shards",
  "require_data": true,
  "cache_shards": 2,
  "shuffle": false,
  "chunk_shuffle": true,
  "chunk_shuffle_seed": 2026,
  "shuffle_rows_within_chunk": true,
  "num_workers": 0,
  "fixture_size": 8,
  "train_limit": 12,
  "val_limit": 6,
  "seq_len": 128,
  "batch_size": 2,
  "max_steps": 4,
  "lr": 0.0004,
  "grad_clip": 1.0,
  "device": "auto",
  "output_dir": "TropicalGT-I/outputs/gpu_smoke",
  "checkpoint_dir": "TropicalGT-I/checkpoints",
  "checkpoint_every": 1,
  "keys_path": "keys.txt",
  "viz_limit": 6,
  "tokengt": {"max_nodes": 48, "max_edges": 96, "node_id_dim": 16, "feature_dim": 48, "graph_token": true},
  "model": {"dim": 96, "hidden_dim": 96, "graph_feature_dim": 48, "num_actions": 8, "gflownet_weight": 0.02, "graphcg_weight": 0.02, "certificate_weight": 0.001, "wall_margin_threshold": 0.001},
  "inference_scaling": {"depth": 2, "width": 3, "branch_factor": 2},
  "wandb": {"enabled": true, "mode": "online", "project": "TropicalGT-I"}
}
